        "probeStimA": "PIR",
        "probeRelation": "SAME",
        "probeStimB": "ZUB",
        "correctAnswer": false,
        "explanation": "PIR=MOQ but MOQ≠ZUB, so PIR≠ZUB."
      },
      {
        "id": "s2_t4",
        "premises": [
          {"stimulusA": "TEL", "relationType": "SAME", "stimulusB": "BEQ"},
